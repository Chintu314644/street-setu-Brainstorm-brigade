{
  "entities": {
    "Obstacle": {
      "title": "Obstacle",
      "description": "A hyper-local street obstacle reported by citizens.",
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "Wedding Tent",
            "Illegal Parking",
            "Construction",
            "Accident",
            "Water-logging",
            "Other"
          ],
          "description": "The category of the obstacle."
        },
        "severity": {
          "type": "string",
          "enum": [
            "Low",
            "Medium",
            "High"
          ],
          "description": "The impact level of the obstacle."
        },
        "description": {
          "type": "string",
          "description": "Details about the blockage."
        },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          },
          "required": ["lat", "lng"],
          "description": "The geographic coordinates of the obstacle."
        },
        "reporterId": {
          "type": "string",
          "description": "The UID of the user who reported it."
        },
        "status": {
          "type": "string",
          "enum": [
            "Active",
            "Cleared"
          ],
          "description": "Current state of the obstacle."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Server timestamp of creation."
        },
        "photoUrl": {
          "type": "string",
          "description": "Optional image proof."
        }
      },
      "required": [
        "type",
        "severity",
        "location",
        "reporterId",
        "status",
        "createdAt"
      ]
    }
  },
  "firestore": {
    "/obstacles/{obstacleId}": {
      "schema": "Obstacle",
      "description": "Collection of all reported street obstacles."
    }
  }
}
